# Copy to .env and fill in for live weather / AQI (optional — triggers still run from DB + ML without keys)
OPENWEATHER_API_KEY=
AQICN_TOKEN=
GOOGLE_MAPS_API_KEY=
IMD_ALERTS_URL=

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Optional: PostgreSQL instead of SQLite
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost/insurgig
